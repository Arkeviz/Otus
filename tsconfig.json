{
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    ".git",
  ],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },

    "module": "ESNext",
    "target": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",

    "types": ["node"], // Глобальные типы vitest не используются согласно конфигу ESLint

    "noUncheckedSideEffectImports": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
  },
}
